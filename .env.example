# Home Assistant Voice - Environment Variables
# Copy this file to .env and fill in your values

# ==================== Home Assistant ====================
# Your Home Assistant instance URL
HOME_ASSISTANT_URL=http://192.168.1.x:8123

# Long-lived access token from Home Assistant
# Create at: Settings > Security > Long-lived access tokens
HOME_ASSISTANT_TOKEN=your_long_lived_token_here

# ==================== GPU Configuration ====================
# Which GPUs to use (comma-separated indices)
# GPU 0: STT (Whisper)
# GPU 1: Embeddings (BGE)
# GPU 2: Router (Qwen)
# GPU 3: TTS (Piper/XTTS)
CUDA_VISIBLE_DEVICES=0,1,2,3

# ==================== Paths ====================
# Directory containing downloaded models
MODELS_PATH=./models

# ChromaDB persistent storage path
CHROMA_PATH=./data/chroma_db

# ==================== Optional Settings ====================
# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Wake word to listen for
WAKE_WORD=hey_jarvis

# TTS engine (piper, xtts, hybrid)
TTS_ENGINE=piper

# ==================== Spotify ====================
# Create app at: https://developer.spotify.com/dashboard
# Add redirect URI: http://localhost:8888/callback
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# ==================== Development ====================
# Enable debug mode (more verbose logging)
DEBUG=false

# Skip model loading for testing
SKIP_MODEL_LOAD=false
