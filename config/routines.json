    {
      "routine_id": "voice_morning",
      "name": "Buenos días",
      "description": "Rutina matutina a las 7am",
      "triggers": [
        {
          "type": "time",
          "config": {
            "at": "07:00:00"
          }
        }
      ],
      "conditions": [
        {
          "type": "weekday",
          "config": {
            "days": [0, 1, 2, 3, 4]
          }
        },
        {
          "type": "presence",
          "config": {
            "is_home": true
          }
        }
      ],
      "actions": [
        {
          "type": "ha_service",
          "entity_id": "cover.bedroom",
          "domain": "cover",
          "service": "open_cover",
          "data": {},
          "description": "Abrir persianas dormitorio"
        },
        {
          "type": "delay",
          "seconds": 5
        },
        {
          "type": "ha_service",
          "entity_id": "light.bedroom",
          "domain": "light",
          "service": "turn_on",
          "data": {
            "brightness_pct": 50,
            "kelvin": 4000
          },
          "description": "Encender luz suave"
        },
        {
          "type": "tts_speak",
          "text": "Buenos días. Son las 7 de la mañana.",
          "zone": "bedroom"
        }
      ],
      "enabled": true,
      "cooldown_seconds": 60,
      "created_at": "2026-02-05T10:00:00",
      "created_by": "voice",
      "tags": ["mañana", "automatica"]
    },
    {
