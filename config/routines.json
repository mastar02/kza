{
  "routines": [
    {
      "routine_id": "voice_welcome_gabriel",
      "name": "Bienvenida Gabriel",
      "description": "Música y clima personalizado cuando llega Gabriel",
      "triggers": [
        {
          "type": "presence_enter",
          "config": {
            "user_id": "gabriel",
            "zone": "home"
          }
        }
      ],
      "conditions": [],
      "actions": [
        {
          "type": "ha_service",
          "entity_id": "climate.home",
          "domain": "climate",
          "service": "set_temperature",
          "data": {"temperature": 22},
          "description": "Temperatura preferida de Gabriel"
        },
        {
          "type": "tts_speak",
          "text": "Hola Gabriel, bienvenido a casa",
          "zone": "living"
        },
        {
          "type": "spotify_play",
          "playlist": "gabriel_favorites",
          "zone": "living"
        }
      ],
      "enabled": true,
      "cooldown_seconds": 300,
      "created_at": "2026-02-05T10:00:00",
      "created_by": "voice",
      "tags": ["presencia", "personal"],
      "owner_user_id": "gabriel",
      "allowed_users": ["gabriel"],
      "guest_allowed": false
    },
    {
      "routine_id": "voice_welcome_generic",
      "name": "Bienvenida a casa",
      "description": "Enciende luces al llegar cualquier persona",
      "triggers": [
        {
          "type": "presence_enter",
          "config": {
            "zone": "home"
          }
        }
      ],
      "conditions": [
        {
          "type": "time_range",
          "config": {
            "start": "18:00",
            "end": "23:00"
          }
        }
      ],
      "actions": [
        {
          "type": "ha_service",
          "entity_id": "light.living_room",
          "domain": "light",
          "service": "turn_on",
          "data": {
            "brightness_pct": 80
          },
          "description": "Encender luz del living"
        },
        {
          "type": "tts_speak",
          "text": "Bienvenido a casa",
          "zone": "living"
        }
      ],
      "enabled": true,
      "cooldown_seconds": 300,
      "created_at": "2026-02-05T10:00:00",
      "created_by": "dashboard",
      "tags": ["presencia", "automatica"],
      "allowed_users": [],
      "guest_allowed": true
    },
