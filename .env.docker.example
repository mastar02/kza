# =============================================================================
# KZA Voice Assistant - Docker Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values

# =============================================================================
# Home Assistant Connection (REQUIRED)
# =============================================================================
HOME_ASSISTANT_URL=http://192.168.1.100:8123
HOME_ASSISTANT_TOKEN=your_long_lived_access_token_here

# =============================================================================
# Model Configuration (Optional - defaults shown)
# =============================================================================

# STT Model (GPU 0)
# Options: distil-whisper/distil-small.en, openai/whisper-large-v3
STT_MODEL=distil-whisper/distil-small.en

# Embeddings Model (GPU 1)
# Options: BAAI/bge-small-en-v1.5, BAAI/bge-m3
EMBEDDINGS_MODEL=BAAI/bge-small-en-v1.5

# Speaker ID Model (GPU 1)
SPEAKER_MODEL=speechbrain/spkrec-ecapa-voxceleb

# Router Model (GPU 2)
# Options: Qwen/Qwen2.5-7B-Instruct, mistralai/Mistral-7B-Instruct-v0.2
ROUTER_MODEL=Qwen/Qwen2.5-7B-Instruct

# TTS Engine and Model (GPU 3)
# TTS_ENGINE: piper (fast) or xtts (quality)
TTS_ENGINE=piper
PIPER_MODEL=es_ES-davefx-medium

# LLM Reasoner (CPU)
# Make sure the model file exists in ./models/
# Recommended for 128GB RAM: Q8_0 quantization
# LLM_MODEL_PATH is set in docker-compose.yml, not here

# =============================================================================
# Performance Tuning (Optional)
# =============================================================================

# vLLM GPU memory utilization (0.0-1.0)
GPU_MEMORY_UTILIZATION=0.85

# LLM Context size
N_CTX=32768

# LLM CPU threads (match your core count)
N_THREADS=24

# LLM Batch size
N_BATCH=512

# =============================================================================
# Paths (Optional - defaults work with docker-compose volumes)
# =============================================================================

# These are typically set in docker-compose.yml
# MODELS_PATH=./models
# DATA_PATH=./data
# LOGS_PATH=./logs
