# LLM Reasoner Service - CPU-based with llama-cpp-python
# Optimized for Threadripper PRO (24 cores) and 128GB RAM
FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive
ENV PYTHONUNBUFFERED=1

# Install build tools for llama-cpp-python compilation
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3.11 python3.11-venv python3.11-dev python3-pip \
    git curl wget build-essential cmake \
    && rm -rf /var/lib/apt/lists/*

RUN update-alternatives --install /usr/bin/python python /usr/bin/python3.11 1
RUN python -m pip install --upgrade pip

WORKDIR /app

# Install llama-cpp-python with CPU optimizations
# AVX2, FMA, F16C for Zen5 architecture
ENV CMAKE_ARGS="-DLLAMA_NATIVE=ON -DLLAMA_AVX2=ON -DLLAMA_FMA=ON -DLLAMA_F16C=ON"
RUN pip install --no-cache-dir \
    llama-cpp-python>=0.2.0 \
    fastapi>=0.104.0 \
    uvicorn[standard]>=0.24.0 \
    pydantic>=2.0.0

# Copy service code
COPY src/llm /app/src/llm
COPY docker/services/reasoner_service.py /app/service.py

RUN useradd -m -u 1000 kza && chown -R kza:kza /app
USER kza

EXPOSE 8005
CMD ["uvicorn", "service:app", "--host", "0.0.0.0", "--port", "8005", "--workers", "1"]
